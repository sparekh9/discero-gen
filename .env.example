# Required: your OpenAI API key.
OPENAI_API_KEY=sk-...

# Optional: Tavily API key for web search grounding.
# If absent, discero falls back to Wikipedia + arXiv only.
TAVILY_API_KEY=

# Optional: override the primary and mini models.
# DISCERO_MODEL=gpt-4o-2024-08-06
# DISCERO_MINI_MODEL=gpt-4o-mini
